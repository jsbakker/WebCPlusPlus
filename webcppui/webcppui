	# create a random colour ===============================================
	def random_color(self):
		Ran = Random()
		Ran.seed()
		rval = Ran.randint(0, 65535)
		gval = Ran.randint(0, 65535)
		bval = Ran.randint(0, 65535)
		color = gtk.gdk.Color(rval, gval, bval)
		return color


