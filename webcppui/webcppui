	# set colour from data pair ============================================
	def set_colour_pair(self, element, hexcode):

		if element == "bgcolor" or element == "backgnd":
			self.c_backgnd.set_color(gtk.gdk.color_parse(hexcode))

		else:
			setc = 'self.c_' + element + '.set_color(gtk.gdk.color_parse(hexcode))'
			eval(setc)


	# load colour scheme ===================================================
	def read_scs_data(self):

		chooser = gtk.FileChooserDialog("Input File", None, gtk.FILE_CHOOSER_ACTION_OPEN,
						(gtk.STOCK_CANCEL, gtk.RESPONSE_CANCEL,
						gtk.STOCK_OPEN, gtk.RESPONSE_OK))

		chooser.set_default_response(gtk.RESPONSE_OK)
		filter = gtk.FileFilter()
		filter.set_name("Webcpp Systax Colour Scheme 2 (*.Scs2)")
		filter.add_pattern("*.Scs2")
		chooser.add_filter(filter)

		response = chooser.run()
		if response == gtk.RESPONSE_OK:
			self.ScsFile = chooser.get_filename()
		else:
			chooser.destroy()
			return

		chooser.destroy()

		try:
			file = open(self.ScsFile, "r")
		except IOError:
			print('Cannot open file for reading:'), self.ScsFile
			self.set_typical()
			return

		scs_lines = file.readlines()

		for scsline in scs_lines:

			hexmatch = re.search('>([0-9a-f]{6})</', scsline, re.IGNORECASE)
			tagmatch = re.search('</([a-z]{7})>', scsline, re.IGNORECASE)

			if hexmatch and tagmatch:
				print(tagmatch.group(1), hexmatch.group(1))
				self.set_colour_pair(tagmatch.group(1), '#' + hexmatch.group(1))

		file.close()
		return


	# open scs file ========================================================
	def on_tbOpen_clicked(self, widget, data=None):

		self.read_scs_data()
		return

	def on_open1_activate(self, widget, data=None):

		self.read_scs_data()
		return


	# convert gtk.gdk.Color to hex string ==================================
	def colour_to_hex(self, col):

		return '%02x%02x%02x' % (col.red/256, col.green/256, col.blue/256)


	# write scs data =======================================================
	def write_scs_data(self):
		try:
			file = open(self.ScsFile, "w")
		except IOError:
			print('Cannot open file for writing:', self.ScsFile)
			self.set_typical()
			return

		file.write('<?xml version="1.0"?>\n')
		file.write('<!DOCTYPE SyntaxColourScheme2 SYSTEM "WebcppScheme2.dtd">\n')
		file.write('<SyntaxColourScheme2>\n')

		hexcol = self.colour_to_hex( self.c_backgnd.get_color() )
		file.write('  <bgcolor>' + hexcol + '</bgcolor>\n')

		hexcol = self.colour_to_hex( self.c_preproc.get_color() )
		file.write('  <preproc>' + hexcol + '</preproc>\n')

		hexcol = self.colour_to_hex( self.c_nortext.get_color() )
		file.write('  <nortext>' + hexcol + '</nortext>\n')

		hexcol = self.colour_to_hex( self.c_symbols.get_color() )
		file.write('  <symbols>' + hexcol + '</symbols>\n')

		hexcol = self.colour_to_hex( self.c_keyword.get_color() )
		file.write('  <keyword>' + hexcol + '</keyword>\n')

		hexcol = self.colour_to_hex( self.c_keytype.get_color() )
		file.write('  <keytype>' + hexcol + '</keytype>\n')

		hexcol = self.colour_to_hex( self.c_integer.get_color() )
		file.write('  <integer>' + hexcol + '</integer>\n')

		hexcol = self.colour_to_hex( self.c_floatpt.get_color() )
		file.write('  <floatpt>' + hexcol + '</floatpt>\n')

		hexcol = self.colour_to_hex( self.c_dblquot.get_color() )
		file.write('  <dblquot>' + hexcol + '</dblquot>\n')

		hexcol = self.colour_to_hex( self.c_sinquot.get_color() )
		file.write('  <sinquot>' + hexcol + '</sinquot>\n')

		hexcol = self.colour_to_hex( self.c_comment.get_color() )
		file.write('  <comment>' + hexcol + '</comment>\n')

		file.write('</SyntaxColourScheme2>\n')
		file.close()


