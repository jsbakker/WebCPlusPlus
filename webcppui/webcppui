	# formulate webcpp options and prepare processing ======================
	def on_btnColour_clicked(self, widget, data=None):
		print('clicked colour')

		options = ' --auto:f'

		if self.entAdvanced.get_text() != "":
			options += ' ' + self.entAdvanced.get_text()

		if self.chkNumbers.get_active():
			print('Show Line Numbers is checked.')
			options += ' -l'

		if self.chkAnchors.get_active():
			print('Make Line Anchors is checked.')
			options += ' -a'

		if self.chkTabSpaces.get_active():
			print('Tabs to Spaces is checked.')
			options += ' -t'

		if self.chkSnippet.get_active():
			print('Snippet Only is checked.')
			options += ' -s'

		if self.chkHyper.get_active():
			print('HyperInclude is checked.')
			options += ' -h'

		if self.chkSuper.get_active():
			print('SuperInclude is checked.')
			options += ' -H'

		if self.chkWebcpp.get_active():
			print('Made with Webcpp is checked.')
			options += ' -m'

		if self.chkExternal.get_active():
			print('External StyleSheet is checked.')
			options += ' -X'

		if self.ScsFile != "":
			options += ' -c=' + self.ScsFile

		self.files_model.foreach(self.colour_file, options)


	# remove file from list ================================================
	def on_btnRemove_clicked(self, widget, data=None):

		sel = self.tvInputFiles.get_selection()
		model, iter = sel.get_selected()
		iter = model.remove(iter)
		return


	# view source code file in editor ======================================
	def on_btnViewSrc_clicked(self, widget, data=None):

		sel = self.tvInputFiles.get_selection()
		model, iter = sel.get_selected()
		file = model.get_value(iter, 0)
		view = 'gedit ' + file + " &"
		os.system(view)
		print(file)
		return


	# view webcpp output file in browser ===================================
	def on_btnViewHtm_clicked(self, widget, data=None):

		sel = self.tvInputFiles.get_selection()
		model, iter = sel.get_selected()
		file = model.get_value(iter, 0)
		view = 'mozilla ' + file + ".html &"
		os.system(view)
		print(file)
		return


	# webcpp menu items ====================================================
	def on_colourize1_activate(self, widget, data=None):
		self.on_btnColour_clicked(widget)

	def on_source_code1_activate(self, widget, data=None):
		self.on_btnViewSrc_clicked(widget)

	def on_html_output1_activate(self, widget, data=None):
		self.on_btnViewHtm_clicked(widget)


	# about webcppui =======================================================
	def goto_url(self, dialog, website, data=None):
		visit = 'mozilla ' + website + ' &'
		os.system(visit)

	def on_tbAbout_clicked(self, widget, data=None):

		try:
			file = open("COPYING", "r")
		except IOError:
			print('Cannot open license file for reading')
			license = "GNU General Public License (GPL)"

		license = file.read()
		authors = ["Webcpp & WebcppUI by Jeffrey Bakker", "GladeWrapper by Padraig Brady"]

		about = gtk.AboutDialog()

		gtk.about_dialog_set_url_hook(self.goto_url, "http://webcpp.sourceforge.net")

		about.set_name("(g)WebcppUI")
		about.set_version("2.0.1")
		about.set_copyright("(C)2006 Jeffrey Bakker")
		about.set_authors(authors)
		about.set_license(license)
		about.set_website("http://webcpp.sourceforge.net")
		about.set_website_label("http://webcpp.sf.net")

		about.run()
		about.destroy()

	def on_about1_activate(self, widget, data=None):
		self.on_tbAbout_clicked(widget)


